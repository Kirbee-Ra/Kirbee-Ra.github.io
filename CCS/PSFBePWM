//###########################################################################
//
// 파일:   PSFB_PWM.c
//
// 제목:  PSFB Soft Start 구현 코드
//
// 설명:
// 이 코드는 TMS320F28379의 ePWM1-2 모듈을 사용하여
// 100kHz PWM 신호를 생성하고, 100 ns 데드타임을 적용합니다.
//
// Q1: ePWM1A  (leading upper)
// Q2: ePWM1B  (leading lower)
// Q3: ePWM2A  (lagging upper)
// Q4: ePWM2B  (lagging lower)
// GPIO62: 외부 스위치 입력
//
// 목표 위상:
// - 초기: Q1 상승 후 5.0 us 뒤에 Q4 상승  -> 180 deg
// - 최종: Q1 상승 후 1.7 us 뒤에 Q4 상승  -> deadtime 보정 포함
//
// 동작:
// - GPIO62 ON  -> ePWM2 interrupt 시작
// - 10 ms마다 lagging leg 위상을 0.1 us씩 앞당김
// - deadtime 보정을 위해 총 33번 업데이트 -> 총 3.3 us 앞당김
// - 이후 위상 유지
// - GPIO62 OFF -> interrupt 종료 + 초기 위상으로 복귀
//
//###########################################################################

#include "F28x_Project.h"

// ===== ISR 선언 =====
interrupt void epwm2_isr(void);

// ===== 함수 선언 =====
void InitEPwm1(void);
void InitEPwm2(void);
void InitEPwm2Interrupt(void);

// ===== 시스템 및 PWM 설정 =====
#define SYSCLKOUT           200000000UL
#define PWM_FREQ            100000UL
#define DUTY_CYCLE          50U
#define EPWMCLK_HZ          (SYSCLKOUT/2UL)      // 100 MHz
#define TBCLK_HZ            (EPWMCLK_HZ)         // 100 MHz

#define TBPRD_VALUE         ((Uint16)((Uint32)TBCLK_HZ / PWM_FREQ) - 1U)   // 999
#define CMPA_VALUE          ((Uint16)((((Uint32)TBPRD_VALUE + 1UL) * DUTY_CYCLE) / 100UL)) // 500
#define DEAD_TIME_TICKS     10U                  // 100 ns @ 100 MHz

// ===== Soft-start 설정 =====
// Q1 rising 기준으로 Q4 rising delay:
// delay ≈ 500 - TBPHS   (deadtime 무시한 이상적 값)
// 실제는 deadtime 10 tick 영향이 있으므로 1 step 추가 보정
//
// 초기 delay = 500 tick (5.0 us, 180 deg)  -> TBPHS = 0
// 최종 delay = 170 tick (1.7 us)           -> TBPHS = 330
#define PHASE_INIT_TICKS    0U
#define PHASE_FINAL_TICKS   330U
#define PHASE_STEP_TICKS    10U                  // 0.1 us = 10 tick
#define UPDATE_PERIOD_COUNT 1000U                // 1000 PWM period = 10 ms

// GPIO62 active-low 스위치 기준
// active-high면 0으로 바꾸면 됨
#define SW_ACTIVE_LOW       1U

// ===== 전역 변수 =====
volatile Uint16 g_phaseTicks      = PHASE_INIT_TICKS;
volatile Uint16 g_periodCount     = 0U;
volatile Uint16 g_softStartActive = 0U;
volatile Uint16 g_swNow           = 0U;
volatile Uint16 g_swPrev          = 0U;


// ePWM1 #####################################################################
// leading leg: Q1/Q2

void InitEPwm1(void)
{
    EALLOW;

    // GPIO0 = ePWM1A, GPIO1 = ePWM1B
    GpioCtrlRegs.GPAMUX1.bit.GPIO0 = 1;
    GpioCtrlRegs.GPAMUX1.bit.GPIO1 = 1;

    EDIS;

    EPwm1Regs.TBPRD = TBPRD_VALUE;
    EPwm1Regs.TBPHS.bit.TBPHS = 0;
    EPwm1Regs.TBCTR = 0;

    EPwm1Regs.TBCTL.bit.CTRMODE   = TB_COUNT_UP;
    EPwm1Regs.TBCTL.bit.PHSEN     = TB_DISABLE;      // master
    EPwm1Regs.TBCTL.bit.HSPCLKDIV = TB_DIV1;
    EPwm1Regs.TBCTL.bit.CLKDIV    = TB_DIV1;
    EPwm1Regs.TBCTL.bit.PRDLD     = TB_SHADOW;
    EPwm1Regs.TBCTL.bit.SYNCOSEL  = TB_CTR_ZERO;     // sync out @ CTR=0

    EPwm1Regs.CMPA.bit.CMPA = CMPA_VALUE;
    EPwm1Regs.CMPB.bit.CMPB = 0;
    EPwm1Regs.CMPCTL.bit.SHDWAMODE = CC_SHADOW;
    EPwm1Regs.CMPCTL.bit.SHDWBMODE = CC_SHADOW;
    EPwm1Regs.CMPCTL.bit.LOADAMODE = CC_CTR_ZERO;
    EPwm1Regs.CMPCTL.bit.LOADBMODE = CC_CTR_ZERO;

    EPwm1Regs.AQCTLA.bit.ZRO = AQ_SET;
    EPwm1Regs.AQCTLA.bit.CAU = AQ_CLEAR;

    EPwm1Regs.DBCTL.bit.OUT_MODE = DB_FULL_ENABLE;
    EPwm1Regs.DBCTL.bit.IN_MODE  = DBA_ALL;
    EPwm1Regs.DBCTL.bit.POLSEL   = DB_ACTV_HIC;
    EPwm1Regs.DBRED.bit.DBRED    = DEAD_TIME_TICKS;
    EPwm1Regs.DBFED.bit.DBFED    = DEAD_TIME_TICKS;
}


// ePWM2 #####################################################################
// lagging leg: Q3/Q4

void InitEPwm2(void)
{
    EALLOW;

    // GPIO2 = ePWM2A, GPIO3 = ePWM2B
    GpioCtrlRegs.GPAMUX1.bit.GPIO2 = 1;
    GpioCtrlRegs.GPAMUX1.bit.GPIO3 = 1;

    EDIS;

    EPwm2Regs.TBPRD = TBPRD_VALUE;
    EPwm2Regs.TBPHS.bit.TBPHS = PHASE_INIT_TICKS;
    EPwm2Regs.TBCTR = 0;

    EPwm2Regs.TBCTL.bit.CTRMODE   = TB_COUNT_UP;
    EPwm2Regs.TBCTL.bit.PHSEN     = TB_ENABLE;       // slave
    EPwm2Regs.TBCTL.bit.HSPCLKDIV = TB_DIV1;
    EPwm2Regs.TBCTL.bit.CLKDIV    = TB_DIV1;
    EPwm2Regs.TBCTL.bit.PRDLD     = TB_SHADOW;
    EPwm2Regs.TBCTL.bit.SYNCOSEL  = TB_SYNC_IN;      // sync 받음

    EPwm2Regs.CMPA.bit.CMPA = CMPA_VALUE;
    EPwm2Regs.CMPB.bit.CMPB = 0;
    EPwm2Regs.CMPCTL.bit.SHDWAMODE = CC_SHADOW;
    EPwm2Regs.CMPCTL.bit.SHDWBMODE = CC_SHADOW;
    EPwm2Regs.CMPCTL.bit.LOADAMODE = CC_CTR_ZERO;
    EPwm2Regs.CMPCTL.bit.LOADBMODE = CC_CTR_ZERO;

    EPwm2Regs.AQCTLA.bit.ZRO = AQ_SET;
    EPwm2Regs.AQCTLA.bit.CAU = AQ_CLEAR;

    EPwm2Regs.DBCTL.bit.OUT_MODE = DB_FULL_ENABLE;
    EPwm2Regs.DBCTL.bit.IN_MODE  = DBA_ALL;
    EPwm2Regs.DBCTL.bit.POLSEL   = DB_ACTV_HIC;
    EPwm2Regs.DBRED.bit.DBRED    = DEAD_TIME_TICKS;
    EPwm2Regs.DBFED.bit.DBFED    = DEAD_TIME_TICKS;

    // ePWM2 interrupt 설정
    EPwm2Regs.ETSEL.bit.INTSEL = ET_CTR_ZERO;
    EPwm2Regs.ETSEL.bit.INTEN  = 0;          // 초기엔 OFF
    EPwm2Regs.ETPS.bit.INTPRD  = ET_1ST;
    EPwm2Regs.ETCLR.bit.INT    = 1;
}


// Interrupt 설정 #############################################################

void InitEPwm2Interrupt(void)
{
    DINT;
    InitPieCtrl();

    IER = 0x0000;
    IFR = 0x0000;

    InitPieVectTable();

    EALLOW;
    PieVectTable.EPWM2_INT = &epwm2_isr;
    EDIS;

    PieCtrlRegs.PIEIER3.bit.INTx2 = 1;   // EPWM2_INT
    IER |= M_INT3;

    EINT;
    ERTM;
}


// main ######################################################################

void main(void)
{
    Uint16 swRaw;

    InitSysCtrl();
    InitGpio();

    // GPIO62 입력 설정
    EALLOW;
    GpioCtrlRegs.GPBMUX2.bit.GPIO62  = 0;   // GPIO 기능
    GpioCtrlRegs.GPBDIR.bit.GPIO62   = 0;   // 입력
    GpioCtrlRegs.GPBPUD.bit.GPIO62   = 0;   // internal pull-up enable
    GpioCtrlRegs.GPBQSEL2.bit.GPIO62 = 2;   // 6-sample qualification
    EDIS;

    // ePWM time-base clock stop
    EALLOW;
    CpuSysRegs.PCLKCR0.bit.TBCLKSYNC = 0;
    EDIS;

    InitEPwm1();
    InitEPwm2();
    InitEPwm2Interrupt();

    // ePWM time-base clock run
    EALLOW;
    CpuSysRegs.PCLKCR0.bit.TBCLKSYNC = 1;
    EDIS;

    // 초기 sync 한 번
    EPwm1Regs.TBCTL.bit.SWFSYNC = 1;

    // 초기 스위치 상태 동기화
    swRaw = GpioDataRegs.GPBDAT.bit.GPIO62;
#if SW_ACTIVE_LOW
    g_swPrev = (swRaw == 0U) ? 1U : 0U;
#else
    g_swPrev = (swRaw != 0U) ? 1U : 0U;
#endif

    while(1)
    {
        swRaw = GpioDataRegs.GPBDAT.bit.GPIO62;

#if SW_ACTIVE_LOW
        g_swNow = (swRaw == 0U) ? 1U : 0U;
#else
        g_swNow = (swRaw != 0U) ? 1U : 0U;
#endif

        // GPIO62 ON: interrupt 시작
        if ((g_swPrev == 0U) && (g_swNow == 1U))
        {
            g_softStartActive = 1U;
            g_periodCount     = 0U;
            g_phaseTicks      = PHASE_INIT_TICKS;

            EPwm2Regs.TBPHS.bit.TBPHS = g_phaseTicks;
            EPwm2Regs.ETCLR.bit.INT   = 1;
            EPwm2Regs.ETSEL.bit.INTEN = 1;

            EPwm1Regs.TBCTL.bit.SWFSYNC = 1;
        }

        // GPIO62 OFF: interrupt 종료 + 초기 위상 복귀
        if ((g_swPrev == 1U) && (g_swNow == 0U))
        {
            g_softStartActive = 0U;
            g_periodCount     = 0U;
            g_phaseTicks      = PHASE_INIT_TICKS;

            EPwm2Regs.ETSEL.bit.INTEN = 0;
            EPwm2Regs.ETCLR.bit.INT   = 1;
            EPwm2Regs.TBPHS.bit.TBPHS = g_phaseTicks;

            EPwm1Regs.TBCTL.bit.SWFSYNC = 1;
        }

        g_swPrev = g_swNow;
    }
}


// ISR #######################################################################
// 10 ms마다 lagging leg phase를 0.1 us씩 앞당김
// deadtime 100 ns 보정을 위해 최종 330 tick까지 진행

interrupt void epwm2_isr(void)
{
    if (g_softStartActive == 1U)
    {
        g_periodCount++;

        if (g_periodCount >= UPDATE_PERIOD_COUNT)   // 10 ms
        {
            g_periodCount = 0U;

            if (g_phaseTicks < PHASE_FINAL_TICKS)
            {
                g_phaseTicks += PHASE_STEP_TICKS;   // 0 -> 330

                if (g_phaseTicks > PHASE_FINAL_TICKS)
                {
                    g_phaseTicks = PHASE_FINAL_TICKS;
                }

                EPwm2Regs.TBPHS.bit.TBPHS = g_phaseTicks;
                EPwm1Regs.TBCTL.bit.SWFSYNC = 1;
            }
        }
    }

    EPwm2Regs.ETCLR.bit.INT = 1;
    PieCtrlRegs.PIEACK.all = PIEACK_GROUP3;
}
